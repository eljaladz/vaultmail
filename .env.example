# ============================================================
# Netlify / Next.js App Environment Variables
# ============================================================

# MongoDB (required for production)
MONGODB_URI=
MONGODB_DB=vaultmail

# Admin password (required)
ADMIN_PASSWORD=

# Webhook shared secret (required for production)
# Must match the Worker's WEBHOOK_SECRET
WEBHOOK_SECRET=

# Cron endpoint shared secret (recommended for production)
CRON_SECRET=

# Optional: allow unauthenticated webhook calls for local development only
# NEVER set this to 'true' in production
ALLOW_UNAUTHENTICATED_WEBHOOK=

# Optional: public URL used for favicon fallback redirects and absolute links
# Example: https://mail.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: default UI locale ('en' or 'id')
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Optional: Google AdSense client ID
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Optional: maximum attachment size in bytes (default: 2_000_000)
ATTACHMENT_MAX_BYTES=2000000

# Optional: Cloudflare Turnstile keys for admin login bot protection
# NEXT_PUBLIC_* is required for the widget to appear on /admin
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: Cloudflare admin API token for domain onboarding via Admin UI
# Required permissions: Zone:Zone:Write, Zone:Zone:Read, Zone:Email Routing Rules:Write, Zone:Zone Settings:Write
# Separate from the Worker deploy token (CLOUDFLARE_API_TOKEN in GitHub Actions).
# Leave empty to disable the "Add domain via Cloudflare" feature in the admin panel.
CLOUDFLARE_ADMIN_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: Global Cloudflare nameservers for domain request modal display
# Comma-separated, e.g. bob.ns.cloudflare.com,lola.ns.cloudflare.com
# Shown to users in the "Request new domain" modal so they know what NS to expect.
# If not set, the modal shows generic instructions without specific nameservers.
# Use NEXT_PUBLIC_ prefix if you want it available client-side (recommended for modal display)
NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_NAMESERVERS=

# ============================================================
# Worker-Only Environment Variables (Cloudflare Worker)
# Do NOT add these to Netlify — set them with wrangler secret put
# ============================================================

# Target webhook URL (the Netlify app URL)
WEBHOOK_URL=https://<your-app>.netlify.app/api/webhook

# Shared secret (must match Netlify WEBHOOK_SECRET) - set via: npx wrangler secret put WEBHOOK_SECRET
# WEBHOOK_SECRET=

# Comma-separated list of domains to accept email for
FORWARD_DOMAINS=yourdomain1.com,yourdomain2.com

# Optional: forward copies to a real mailbox
FORWARD_EMAIL=

# ============================================================
# Development / Seeding Helpers
# ============================================================

# Domains are configured via the Admin UI after deploy.
# Edit lib/domain-config.seed.ts and run scripts/seed-domains.ts if you prefer to seed from code.
